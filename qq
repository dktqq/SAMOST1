import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        String[] products = {"Молоко", "Хлеб", "Гречневая крупа"};
        int[] prices = {50, 14, 80};
        int[] cart = new int[products.length];
        System.out.println("Список возможных товаров для покупки:");
        for (int i = 0; i < products.length; i++) {
            System.out.println((i + 1) + ". " + products[i] + " " + prices[i] + " руб/шт");
        }
        while (true) {
            System.out.println("\nВыберите товар и количество или введите end");
            String input = scanner.nextLine();
            if (input.equals("end")) {
                break;
            }
            String[] parts = input.split(" ");
            if (parts.length != 2) {
                System.out.println("Некорректный ввод. Попробуйте снова.");
                continue;
            }

            try {
                int productNumber = Integer.parseInt(parts[0]) - 1;
                int productCount = Integer.parseInt(parts[1]);
                if (productNumber < 0 || productNumber >= products.length) {
                    System.out.println("Товара с таким номером нет. Попробуйте снова.");
                    continue;
                }
                if (productCount <= 0) {
                    System.out.println("Количество должно быть больше нуля. Попробуйте снова.");
                    continue;
                }
                cart[productNumber] += productCount;
                System.out.println("Добавлено: " + products[productNumber] + " " + productCount + " шт");

            } catch (NumberFormatException e) {
                System.out.println("Ошибка ввода. Введите номер и количество через пробел.");
            }
        }
        System.out.println("\nВаша корзина:");
        int totalSum = 0;

        for (int i = 0; i < products.length; i++) {
            if (cart[i] > 0) {
                int sum = cart[i] * prices[i];
                totalSum += sum;
                System.out.println(products[i] + " " + cart[i] + " шт " + prices[i] + " руб/шт " + sum + " руб в сумме");
            }
        }

        System.out.println("Итого " + totalSum + " руб");

        scanner.close();
    }
}
